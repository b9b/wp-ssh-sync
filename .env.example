# SSH连接信息。为了安全，仅限密钥登录，并确保本机已配置免密登录。
# 本 Skill 只从项目根目录 .env 读取连接信息，不读取系统环境变量。

SSH_HOST=1.2.3.4
SSH_PORT=22
SSH_USER=site_ssh_user

# 可选：不填写时使用本机 SSH 配置。
# SSH_KEY_PATH=/Users/you/.ssh/id_ed25519
# SSH_EXTRA_OPTS=-o ProxyJump=jump-host

# 远端 WordPress 根目录，必须能在该目录执行 wp。
WP_PATH=/www/wwwroot/example.com

# 同步目录映射。格式：本地目录:远端目录
# 本地目录相对目标项目根目录；远端目录相对 WP_PATH。
# 开头的 / 仅表示项目/WP 根下路径，不表示服务器或本机系统根目录。
# 需要同步多个目录时继续添加 SYNC_MAP_2、SYNC_MAP_3...
SYNC_MAP_1=/theme1:/theme1
# SYNC_MAP_2=/theme2:/theme2
# SYNC_MAP_3=/plugins/my-plugin:/wp-content/plugins/my-plugin

# 可选：同步忽略规则文件。未配置时默认读取项目根目录 .wp-ssh-sync.ignore。
SYNC_IGNORE_FILE=.wp-ssh-sync.ignore
