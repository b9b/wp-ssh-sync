# Copy this file to the target project root as .env and fill in real values.
# Never commit .env or private keys.

SSH_HOST=example.com
SSH_PORT=22
SSH_USER=deploy
SSH_KEY_PATH=/Users/you/.ssh/id_ed25519
SSH_EXTRA_OPTS=

# Remote WordPress root or another remote root used by the future sync workflow.
WP_PATH=/www/wwwroot/example.com
REMOTE_ROOT=/www/wwwroot/example.com

# Local project root used by the future sync workflow.
LOCAL_ROOT=.
